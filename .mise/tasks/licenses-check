#!/usr/bin/env bash
# shorthand name: licenses-check
# mise skip_shellintegration: true
# description: Verify licenses/ matches current go.mod dependencies (fail with instructions if stale)
set -euo pipefail

_flatten_licenses() {
  local save_dir="$1" out_dir="$2"
  find "$save_dir" -type f -name "LICENSE*" | while read -r f; do
    # Only process files named LICENSE, LICENSE.txt, or LICENSE.md
    basename_f="$(basename "$f")"
    case "$basename_f" in
      LICENSE|LICENSE.txt|LICENSE.md) ;;
      *) continue ;;
    esac
    local rel="${f#$save_dir/}"
    local dir="${rel%/*}"
    for prefix in "github.com/" "gopkg.in/" "golang.org/x/" "go.uber.org/" "google.golang.org/"; do
      dir="${dir#$prefix}"
    done
    local name="${dir//\//-}"
    name="$(echo "$name" | sed 's/-v[0-9][0-9]*$//')"
    name="$(echo "$name" | sed 's/\.v[0-9][0-9]*$//')"
    cp "$f" "${out_dir}/${name}-license.MD"
  done
}

SAVE_DIR="$(mktemp -d)"
TMPOUT="$(mktemp -d)"
trap 'rm -rf "$SAVE_DIR" "$TMPOUT"' EXIT

go-licenses save ./... \
  --save_path="$SAVE_DIR" \
  --force \
  --ignore github.com/Eun/merge-with-label

_flatten_licenses "$SAVE_DIR" "$TMPOUT"

if ! diff -rq "$TMPOUT" licenses/ >/dev/null 2>&1; then
  echo ""
  echo "ERROR: licenses/ is out of date with the current go.mod dependencies."
  echo "Run the following command and commit the result:"
  echo ""
  echo "    mise run licenses"
  echo ""
  diff -r "$TMPOUT" licenses/ || true
  exit 1
fi
echo "licenses/ is up to date."
